[Unit]
Description=Tablón Corporativo - Backend FastAPI
After=network.target mysql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/tablon_backend
EnvironmentFile=/opt/tablon_backend/.env
ExecStart=/opt/tablon_backend/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
